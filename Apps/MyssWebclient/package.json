{
  "name": "myss-webclient",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "npx prettier . --write",
    "format:check": "npx prettier . --check",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest --config=vitest.config.ts --project=unit",
    "test:browser": "vitest --config=vitest.config.ts --project=browser",
    "test:browser-headless": "vitest --config=vitest.config.ts --project=browser --browser.headless",
    "generate:schema": "node --env-file=.env node_modules/.bin/openapi-ts --file openapi-ts.config.ts"
  },
  "dependencies": {
    "@bcgov/bc-sans": "2.1.0",
    "@bcgov/design-system-react-components": "0.6.0",
    "@bcgov/design-tokens": "3.2.0",
    "@tanstack/react-query": "5.90.20",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@hey-api/openapi-ts": "^0.94.2",
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@types/node": "25.2.0",
    "@types/react": "19.2.11",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.3",
    "@vitest/browser-playwright": "4.0.18",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.0",
    "globals": "17.3.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.1",
    "vitest-browser-react": "2.0.5"
  }
}
